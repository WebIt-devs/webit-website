rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Lock down the contact submissions collection
    match /contact_submissions/{docId} {
      // Allow public creation of new contact submissions
      // This allows anyone to submit the form
      allow create: if true;
      
      // Explicitly block reading, updating, or deleting submissions from the web client
      // Only you (via the Firebase Console or Admin SDK) can read/mutate these records
      allow read, update, delete: if false;
    }

    // Default deny for any other collections
    // Secures against arbitrary collection creation attacks
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
